# ============================
# Скопируй в .env и заполни
# ============================

# ── Провайдер модели ───────────────────────────
# "ollama"   — локальная модель (по умолчанию)
# "anthropic" — облако Claude (опционально)
LLM_PROVIDER=ollama

# ── Ollama (локальный режим) ───────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Модель. Лестница по железу (тег Ollama → нужная VRAM при Q4):
#   qwen3:235b   ← максимум, нужен сервер (~140+ ГБ, MoE)
#   qwen3:30b    ← баланс, ~24 ГБ VRAM
#   qwen3:14b    ← рабочая на ~12 ГБ
#   qwen3:8b     ← минимум, ~8 ГБ
LLM_MODEL=qwen3:235b

LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ── Anthropic (только если LLM_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=

# ── Приложение ─────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ── Хранилище ──────────────────────────────────
CHROMA_PATH=./chroma_data
UPLOADS_PATH=./uploads

# ── Память проектов (PostgreSQL) ───────────────
# Локально (без Docker) — поднимите Postgres сами и укажите свой DSN.
# В docker-compose сервис postgres доступен по имени хоста "postgres".
DATABASE_URL=postgresql+asyncpg://bureau:bureau@localhost:5432/bureau

# ── Коннектор Компас-3D (опционально, Windows) ──
# Отдельный сервис kompas-connector на Windows с установленным Компас-3D.
# Если не запущен — операции с чертежами вернут ошибку, платформа работает.
KOMPAS_CONNECTOR_URL=http://localhost:8100
